# ── API Proxy ────────────────────────────────────────────
# Proxied via next.config.mjs rewrites: /api/* → http://localhost:8000/api/*
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ── Dev Mode ─────────────────────────────────────────────
# Set to "true" to bypass backend auth and preview all pages without a running backend
NEXT_PUBLIC_SKIP_AUTH=false
