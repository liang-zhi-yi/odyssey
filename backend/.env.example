# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string. When using docker-compose, use:
#   DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/odyssey
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/odyssey

# ── JWT ───────────────────────────────────────────────────
# Generate a random secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── LLM Provider ──────────────────────────────────────────
# Choose a provider preset. Available options:
#
#   openai     → api.openai.com            (GPT-4o, full structured output)
#   deepseek   → api.deepseek.com          (DeepSeek-V3/R1)
#   bailian    → dashscope.aliyuncs.com    (阿里百炼 Qwen 系列)
#   zhipu      → open.bigmodel.cn          (智谱AI GLM 系列)
#   moonshot   → api.moonshot.cn           (月之暗面 Kimi)
#   openrouter → openrouter.ai             (多平台代理，支持 Claude/GPT/Gemini)
#   claude     → api.anthropic.com         (⚠️ 非 OpenAI 兼容，需用 openrouter)
#   custom     → 自定义兼容 API
#
LLM_PROVIDER=openai

# API key for the provider selected above (REQUIRED for assessment)
#   OpenAI:     https://platform.openai.com/api-keys
#   DeepSeek:   https://platform.deepseek.com
#   Bailian:    https://bailian.console.aliyun.com
#   Zhipu:      https://open.bigmodel.cn
#   Moonshot:   https://platform.moonshot.cn
#   OpenRouter: https://openrouter.ai/keys
LLM_API_KEY=sk-your-api-key-here

# Custom base URL — overrides the provider preset's default URL.
# Leave empty to use the preset's built-in URL.
# Example (Ollama local):   LLM_BASE_URL=http://localhost:11434/v1
# Example (LiteLLM proxy):  LLM_BASE_URL=http://localhost:4000/v1
LLM_BASE_URL=

# Model name — provider-specific. Leave empty to use the provider's default.
#   openai:     gpt-4o | gpt-4-turbo | gpt-4o-mini
#   deepseek:   deepseek-chat | deepseek-reasoner
#   bailian:    qwen-plus | qwen-max | qwen-turbo
#   zhipu:      glm-4-flash | glm-4 | glm-4-plus
#   moonshot:   moonshot-v1-8k | moonshot-v1-32k | moonshot-v1-128k
#   openrouter: openai/gpt-4o | anthropic/claude-sonnet-4-6 | google/gemini-2.5-pro
LLM_MODEL=gpt-4o

# Assessment temperature — 0.0 = deterministic (recommended for fairness)
LLM_TEMPERATURE=0.0

# Timeout per LLM call in seconds
LLM_TIMEOUT_SECONDS=60

# ── Debug ─────────────────────────────────────────────────
DB_ECHO=false
